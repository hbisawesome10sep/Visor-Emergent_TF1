{
  "identity": {
    "name": "Visor 2.0",
    "aesthetic": "Cyber-Fintech Luxury",
    "core_principles": [
      "Void Black & Stark White: No muddy greys. Maximum contrast.",
      "Neon Bloom: Interactive elements glow. Data pops.",
      "Liquid Motion: Everything flows. Static is dead.",
      "Precision Typography: Tight tracking, bold weights, mono-spaced numbers."
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Space Grotesk",
      "body": "Outfit",
      "code": "JetBrains Mono"
    },
    "installation_instructions": [
      "npx expo install @expo-google-fonts/space-grotesk @expo-google-fonts/outfit @expo-google-fonts/jetbrains-mono",
      "Load fonts in app/_layout.tsx using useFonts hook"
    ],
    "scale": {
      "display": { "size": 32, "weight": "700", "tracking": -1, "lineHeight": 40 },
      "h1": { "size": 24, "weight": "700", "tracking": -0.5, "lineHeight": 32 },
      "h2": { "size": 20, "weight": "600", "tracking": -0.5, "lineHeight": 28 },
      "body_lg": { "size": 16, "weight": "400", "tracking": 0, "lineHeight": 24 },
      "body_sm": { "size": 14, "weight": "400", "tracking": 0, "lineHeight": 20 },
      "caption": { "size": 12, "weight": "500", "tracking": 0.5, "lineHeight": 16, "transform": "uppercase" }
    }
  },
  "colors": {
    "palette": {
      "common": {
        "black": "#000000",
        "white": "#FFFFFF",
        "transparent": "transparent"
      },
      "neon": {
        "green": "#39FF14",
        "red": "#FF073A",
        "orange": "#FF6B00",
        "cyan": "#00FFD1",
        "blue": "#00B4FF",
        "purple": "#B026FF",
        "yellow": "#FFE600"
      }
    },
    "themes": {
      "dark": {
        "background": "#000000",
        "surface": "#09090B",
        "surfaceHighlight": "#18181B",
        "textPrimary": "#FFFFFF",
        "textSecondary": "#A1A1AA",
        "border": "#27272A",
        "primary": "#00FFD1",
        "secondary": "#B026FF",
        "success": "#39FF14",
        "error": "#FF073A",
        "warning": "#FFE600",
        "info": "#00B4FF",
        "glassBg": "rgba(9, 9, 11, 0.7)",
        "glassBorder": "rgba(255, 255, 255, 0.1)",
        "cardShadow": "#00FFD1"
      },
      "light": {
        "background": "#FFFFFF",
        "surface": "#FAFAFA",
        "surfaceHighlight": "#F4F4F5",
        "textPrimary": "#000000",
        "textSecondary": "#52525B",
        "border": "#E4E4E7",
        "primary": "#009080",
        "secondary": "#7C3AED",
        "success": "#059669",
        "error": "#E11D48",
        "warning": "#D97706",
        "info": "#0284C7",
        "glassBg": "rgba(255, 255, 255, 0.8)",
        "glassBorder": "rgba(0, 0, 0, 0.05)",
        "cardShadow": "#000000"
      }
    }
  },
  "components": {
    "LiquidCard": {
      "wrapper": "rounded-3xl border border-white/10 overflow-hidden",
      "style": {
        "shadowColor": "neon.primary",
        "shadowOffset": { "width": 0, "height": 8 },
        "shadowOpacity": 0.4,
        "shadowRadius": 16,
        "elevation": 10
      },
      "gradients": {
        "income": ["#39FF14", "#00B4FF"],
        "expense": ["#FF073A", "#FF6B00"],
        "savings": ["#00FFD1", "#B026FF"]
      }
    },
    "GlassHeader": {
      "style": {
        "blurAmount": 30,
        "borderColor": "rgba(255,255,255,0.1)",
        "borderBottomWidth": 1
      }
    },
    "TabBar": {
      "style": {
        "backgroundColor": "rgba(0,0,0,0.8)",
        "borderTopColor": "rgba(255,255,255,0.1)",
        "blur": true,
        "floating": true,
        "borderRadius": 30,
        "margin": 16,
        "height": 70
      },
      "activeIcon": {
        "glow": true,
        "scale": 1.2
      }
    },
    "Charts": {
      "pie": {
        "strokeWidth": 0,
        "radius": 100,
        "innerRadius": 70,
        "padAngle": 4
      },
      "trend": {
        "strokeWidth": 3,
        "gradientFill": true,
        "bezier": true
      }
    }
  },
  "implementation_steps": [
    "1. INSTALL FONTS: Add @expo-google-fonts/space-grotesk and @expo-google-fonts/outfit.",
    "2. CONFIGURE FONTS: Update app/_layout.tsx to load these fonts before rendering.",
    "3. UPDATE THEME: Replace content of src/utils/theme.ts with the new Color Palette (Neon/Void).",
    "4. UPDATE LAYOUT: Modify app/(tabs)/_layout.tsx to implement the floating glass tab bar.",
    "5. RESTYLE COMPONENTS: Update LiquidFillCard.tsx to use new neon gradients and stronger shadows.",
    "6. GLOBAL STYLES: Ensure all Text components use the new font families (Space Grotesk for headers, Outfit for body).",
    "7. DARK MODE FIX: Ensure the background is true #000000, not slate."
  ],
  "image_urls": {
    "placeholder_user": "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=100&q=80",
    "card_bg_pattern": "https://images.unsplash.com/photo-1550684848-fac1c5b4e853?auto=format&fit=crop&w=800&q=80"
  },
  "instructions_to_main_agent": "You are the Lead Developer. Follow these guidelines strictly. Your goal is a VISUAL OVERHAUL. Do not change business logic. 1. Replace the theme file first. 2. Set up the fonts. 3. Go screen by screen (Dashboard -> Transactions -> Insights) and apply the 'Neon on Void' aesthetic. 4. Use 'Space Grotesk' for all numbers and headers to give it that premium fintech look. 5. Make the 'Liquid' cards pop with neon gradients.",
  "UNIVERSAL_GUIDELINES": "See Phase 5 of the system prompt for general rules."
}
